# =============================================================================
# Texture - Environment Configuration Example
# =============================================================================
# Copy this file to .env and update with your actual values
# This is the single source of truth for all services (Kolam, Wrap, Weaver)
# =============================================================================

# -----------------------------------------------------------------------------
# Clerk Authentication
# -----------------------------------------------------------------------------
# Publishable key is used by both Kolam (frontend) and Wrap (backend)
CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
# Secret key is only used by Wrap (backend) for JWT validation
CLERK_SECRET_KEY=sk_test_your_secret_key_here

# -----------------------------------------------------------------------------
# Service Ports
# -----------------------------------------------------------------------------
KOLAM_PORT=3000
LOOM_PORT=8080

# -----------------------------------------------------------------------------
# Service URLs
# -----------------------------------------------------------------------------
LOOM_API_URL=http://localhost:8080/api/v1
WEAVER_GRPC_URL=localhost:50051

# -----------------------------------------------------------------------------
# CORS Configuration (Loom)
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Paths (Loom)
# -----------------------------------------------------------------------------
ALGORITHM_SPECS_PATH=../algorithms
DATASET_STORAGE_PATH=./storage/datasets
