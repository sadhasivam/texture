# Texture Production Server Configuration
# Serves application via HTTP on port 8080
# Access at: http://YOUR_SERVER_IP:8080
#
# IMPORTANT: Update the root path below to match your deployment directory
# Example: /root/texture/Kolam/dist or /home/youruser/texture/Kolam/dist

{
	# Disable automatic HTTPS for IP address deployment
	auto_https off
}

:80 {
	encode gzip

	# Proxy API requests to backend
	route /api/* {
		reverse_proxy localhost:8000
	}

	# Serve static files with SPA fallback
	route {
		root * /root/texture/Kolam/dist
		try_files {path} /index.html
		file_server
	}

	log {
		output stdout
		format console
	}
}
