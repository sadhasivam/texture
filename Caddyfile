# Texture  project
texture.sadhasivam.net {
	encode gzip

	handle /api/* {
		reverse_proxy 127.0.0.1:8080
	}

	handle {
		reverse_proxy https://texture-gilt.vercel.app {
			header_up Host texture-gilt.vercel.app
		}
	}

	log {
		output stdout
		format console
	}
}

# Jarvis/StockMind project
jarvis.sadhasivam.net {
        encode gzip

        reverse_proxy 127.0.0.1:9999 {
                # Pass through original headers
                header_up Host {host}
                header_up X-Real-IP {remote_host}
                header_up X-Forwarded-For {remote_host}
                header_up X-Forwarded-Proto {scheme}
        }

        log {
                output stdout
                format console
        }
}
